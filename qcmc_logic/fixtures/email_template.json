 {
  "docstatus": 0,
  "doctype": "Email Template",
  "modified": "2026-04-14 10:03:25.229632",
  "name": "Request For Qoutation",
  "response": "<div class=\"ql-editor read-mode\"><p>Dear {{ supplier_name }},</p><p><br></p><p>Please provide your quotation for the following:</p><p><br></p><p>{% for item in items %}</p><p><br></p><p>{{ item.item_name }} | Qty: {{ item.qty }} {{ item.uom }}</p><p><br></p><p>{% endfor %}</p><p><br></p><p>Required By: {{ schedule_date or \"\" }}</p><p><br></p><p>Kindly include price, lead time, and payment terms.</p><p><br></p><p>Thank you.</p><p><br></p><p>Best regards,</p><p>{{ company }}</p></div>",
  "response_html": "<div style=\"margin:0; padding:0; background-color:#efefef;\">\r\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"background-color:#efefef; margin:0; padding:0; width:100%;\">\r\n    <tr>\r\n      <td align=\"center\" style=\"padding:28px 12px;\">\r\n\r\n        <table role=\"presentation\" width=\"640\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"width:100%; max-width:640px; background:#ffffff; border:1px solid #dcdcdc; border-radius:6px;\">\r\n          \r\n          <!-- Header -->\r\n          <tr>\r\n            <td style=\"background:#23a277; padding:30px 32px 38px 32px;\">\r\n              <div style=\"font-family:Arial, Helvetica, sans-serif; font-size:18px; line-height:26px; font-weight:700; color:#ffffff;\">\r\n                {{ company }}\r\n              </div>\r\n              <div style=\"font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:18px; color:#f3fffb; padding-top:6px;\">\r\n                Procurement Department\r\n              </div>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- Meta -->\r\n          <tr>\r\n            <td style=\"background:#f3f3f3; border-bottom:1px solid #e2e2e2; padding:18px 32px;\">\r\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"width:100%; border-collapse:collapse;\">\r\n                <tr>\r\n                  <td valign=\"top\" style=\"width:100px; padding:0 18px 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#8b8b8b; white-space:nowrap;\">\r\n                    Subject\r\n                  </td>\r\n                  <td valign=\"top\" style=\"padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#3d3d3d; font-weight:700; word-break:break-word;\">\r\n                    Request for Quotation (RFQ) – {{ name }} | {{ company }}\r\n                  </td>\r\n                </tr>\r\n                <tr>\r\n                  <td valign=\"top\" style=\"width:100px; padding:0 18px 0 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#8b8b8b; white-space:nowrap;\">\r\n                    To\r\n                  </td>\r\n                  <td valign=\"top\" style=\"padding:0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#555555; word-break:break-word;\">\r\n                    {{ supplier }}\r\n                  </td>\r\n                </tr>\r\n              </table>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- Body -->\r\n          <tr>\r\n            <td style=\"padding:34px 32px 28px 32px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:1.8; color:#2f2f2f;\">\r\n\r\n              <p style=\"margin:0 0 18px 0;\">Dear {{ supplier }},</p>\r\n\r\n              <p style=\"margin:0 0 18px 0;\">\r\n                We hope this message finds you well. We would like to invite you to submit a quotation for\r\n                the items listed below as part of our procurement process.\r\n              </p>\r\n\r\n              <!-- RFQ Info -->\r\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"width:100%; margin:0 0 26px 0; border-collapse:collapse; background:#edf4f2; border-left:4px solid #23a277;\">\r\n                <tr>\r\n                  <td style=\"padding:14px 18px;\">\r\n                    <p style=\"margin:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#5b5b5b;\">\r\n                      RFQ Reference: <span style=\"color:#0b7f62; font-weight:700;\">{{ name }}</span>\r\n                    </p>\r\n                    <p style=\"margin:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#5b5b5b;\">\r\n                      Required By: <span style=\"color:#0b7f62; font-weight:700;\">{{ schedule_date }}</span>\r\n                    </p>\r\n                    <p style=\"margin:0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#5b5b5b;\">\r\n                      Requesting Company: <span style=\"color:#0b7f62; font-weight:700;\">{{ company }}</span>\r\n                    </p>\r\n                  </td>\r\n                </tr>\r\n              </table>\r\n\r\n              <!-- Items title -->\r\n              <p style=\"margin:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; font-weight:700; color:#222222;\">\r\n                Items Requested\r\n              </p>\r\n\r\n              <!-- Items table -->\r\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"width:100%; border-collapse:collapse; margin:0 0 24px 0;\">\r\n                <tr>\r\n                  <td style=\"background:#23a277; padding:10px 12px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:18px; font-weight:700; color:#ffffff;\">Item Name</td>\r\n                  <td style=\"background:#23a277; padding:10px 12px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:18px; font-weight:700; color:#ffffff;\">Item Code</td>\r\n                  <td style=\"background:#23a277; padding:10px 12px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:18px; font-weight:700; color:#ffffff;\">Qty</td>\r\n                  <td style=\"background:#23a277; padding:10px 12px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:18px; font-weight:700; color:#ffffff;\">UOM</td>\r\n                  <td style=\"background:#23a277; padding:10px 12px; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:18px; font-weight:700; color:#ffffff;\">Description</td>\r\n                </tr>\r\n\r\n                {% for item in items %}\r\n                <tr>\r\n                  <td style=\"padding:12px; border-bottom:1px solid #e8e8e8; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f; word-break:break-word;\">{{ item.item_name }}</td>\r\n                  <td style=\"padding:12px; border-bottom:1px solid #e8e8e8; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f; word-break:break-word;\">{{ item.item_code }}</td>\r\n                  <td style=\"padding:12px; border-bottom:1px solid #e8e8e8; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">{{ item.qty }}</td>\r\n                  <td style=\"padding:12px; border-bottom:1px solid #e8e8e8; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">{{ item.uom }}</td>\r\n                  <td style=\"padding:12px; border-bottom:1px solid #e8e8e8; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f; word-break:break-word;\">{{ item.description or item.item_name }}</td>\r\n                </tr>\r\n                {% endfor %}\r\n              </table>\r\n\r\n              <!-- Checklist -->\r\n              <p style=\"margin:0 0 14px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; font-weight:700; color:#222222;\">\r\n                When preparing your quotation, please include:\r\n              </p>\r\n\r\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"width:100%; border-collapse:collapse; margin:0 0 26px 0;\">\r\n                <tr>\r\n                  <td style=\"width:20px; padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">&nbsp;</td>\r\n                  <td style=\"padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">Unit price and total amount per item</td>\r\n                </tr>\r\n                <tr>\r\n                  <td style=\"width:20px; padding:0 0 10px 0;\">&nbsp;</td>\r\n                  <td style=\"padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">Estimated lead time / delivery schedule</td>\r\n                </tr>\r\n                <tr>\r\n                  <td style=\"width:20px; padding:0 0 10px 0;\">&nbsp;</td>\r\n                  <td style=\"padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">Payment terms and conditions</td>\r\n                </tr>\r\n                <tr>\r\n                  <td style=\"width:20px; padding:0 0 10px 0;\">&nbsp;</td>\r\n                  <td style=\"padding:0 0 10px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">Validity period of the quotation</td>\r\n                </tr>\r\n                <tr>\r\n                  <td style=\"width:20px; padding:0;\">&nbsp;</td>\r\n                  <td style=\"padding:0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#2f2f2f;\">Any applicable taxes or additional charges</td>\r\n                </tr>\r\n              </table>\r\n\r\n              <p style=\"margin:0 0 18px 0;\">\r\n                Please submit your quotation at your earliest convenience, but no later than the required\r\n                date above. If you have any questions or need further clarification, please do not hesitate\r\n                to contact us.\r\n              </p>\r\n\r\n              <p style=\"margin:0 0 22px 0;\">\r\n                We look forward to your prompt response and the opportunity to work with you.\r\n              </p>\r\n\r\n              <p style=\"margin:0 0 12px 0;\">Warm regards,</p>\r\n\r\n              {% set emp = frappe.db.get_value(\r\n                \"Employee\",\r\n                {\"user_id\": frappe.session.user},\r\n                [\"employee_name\", \"designation\"],\r\n                as_dict=True\r\n            ) %}\r\n            \r\n                <p style=\"margin:0; color:#23a277; font-weight:700; font-size:14px;\">\r\n                  {{ emp.employee_name if emp else frappe.session.user }}\r\n                </p>\r\n                \r\n                <p style=\"margin:4px 0 0 0; color:#8c8c8c;\">\r\n                  {{ emp.designation if emp and emp.designation else \"Procurement Department\" }}\r\n                </p>\r\n            </td>\r\n          </tr>\r\n\r\n          <!-- Footer -->\r\n          <tr>\r\n            <td style=\"border-top:1px solid #e6e6e6; background:#fafafa; text-align:center; padding:14px 20px; font-family:Arial, Helvetica, sans-serif; font-size:11px; line-height:16px; color:#b2b2b2;\">\r\n              This is an automated email from your ERP system. Please do not reply directly to this message.\r\n            </td>\r\n          </tr>\r\n\r\n        </table>\r\n      </td>\r\n    </tr>\r\n  </table>\r\n</div>",
  "subject": "Request for Quotation (RFQ) – {{ name }} | {{company}}",
  "use_html": 1
 }
]